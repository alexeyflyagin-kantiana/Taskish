<UserControl x:Class="Taskish.Views.PropertyFieldRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Taskish.Controls">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource Gap12}"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="{StaticResource Gap8}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Viewbox Width="18" Height="18">
                <Canvas Width="24" Height="24">
                    <Path Data="{Binding IconData, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          Fill="{StaticResource OnSurfaceVariantBrush}"/>
                </Canvas>
            </Viewbox>
            <TextBlock
                Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Width="160"
                Style="{StaticResource LabelLarge}"
                Foreground="{StaticResource OnSurfaceVariantBrush}"
                VerticalAlignment="Center">
                <TextBlock.Margin>
                    <Thickness Left="{StaticResource Spacing8}"/>
                </TextBlock.Margin>
            </TextBlock>
        </StackPanel>

        <ContentPresenter 
            Grid.Column="3"
            Content="{Binding FieldContent, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
    </Grid>
</UserControl>