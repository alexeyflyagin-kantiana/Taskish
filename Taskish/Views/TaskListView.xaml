<UserControl x:Class="Taskish.Views.TaskListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Taskish.Views"
             xmlns:controls="clr-namespace:Taskish.Controls"
             xmlns:res="clr-namespace:Taskish.Resources">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Обычная шапка -->
        <Grid
            x:Name="normalHeader"
            Grid.Row="0">
            <Grid.Margin>
                <Thickness
                    Left="{StaticResource Spacing8}"
                    Top="{StaticResource Spacing8}"
                    Right="{StaticResource Spacing8}"
                    Bottom="{StaticResource Spacing8}"/>
            </Grid.Margin>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{StaticResource Gap8}"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="{StaticResource Gap4}"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource Gap8}"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="{StaticResource Gap4}"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="1"
                    Style="{StaticResource TitleMedium}"
                    Foreground="{StaticResource OnSurfaceBrush}"
                    Text="{x:Static res:Strings.AllTasks}"
                    VerticalAlignment="Center"/>

                <TextBlock
                    Grid.Column="3"
                    Style="{StaticResource TitleMedium}"
                    Foreground="{StaticResource OnSurfaceVariantBrush}"
                    Text="{Binding TaskCounter}"
                    VerticalAlignment="Center"/>
            </Grid>

            <controls:IconButton
                Grid.Column="2"
                IconData="{StaticResource SearchIcon}"
                Command="{Binding SearchCommand}"/>

            <controls:IconButton
                Grid.Column="4"
                IconData="{StaticResource AddIcon}"
                Command="{Binding AddTaskCommand}"/>

            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSearchActive}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
        </Grid>

        <!-- Поисковая шапка -->
        <local:SearchBar
            Grid.Row="0"
            Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            BackCommand="{Binding CloseSearchCommand}">
            <local:SearchBar.Margin>
                <Thickness
                    Left="{StaticResource Spacing8}"
                    Top="{StaticResource Spacing8}"
                    Right="{StaticResource Spacing8}"
                    Bottom="{StaticResource Spacing8}"/>
            </local:SearchBar.Margin>
            <local:SearchBar.Style>
                <Style TargetType="local:SearchBar">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSearchActive}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </local:SearchBar.Style>
        </local:SearchBar>

        <TextBlock
            Grid.Row="1"
            Text="Пока что пусто — создайте первую задачу"
            Foreground="{StaticResource OnSurfaceVariantBrush}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            TextWrapping="Wrap"
            TextAlignment="Center">
            <TextBlock.Margin>
                <Thickness Left="{StaticResource Spacing24}" Right="{StaticResource Spacing24}"/>
            </TextBlock.Margin>
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource LabelMedium}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <TextBlock
            Grid.Row="1"
            Text="Ничего не найдено"
            Foreground="{StaticResource OnSurfaceVariantBrush}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource LabelMedium}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSearchNoResults}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <controls:TaskListBox
            Grid.Row="1"
            ItemsSource="{Binding TasksView}"
            TaskSelectedCommand="{Binding TaskSelectedCommand}"
            Background="Transparent"
            BorderThickness="0"
            HorizontalContentAlignment="Stretch"
            ScrollViewer.CanContentScroll="False"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <controls:TaskListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="GroupItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GroupItem">
                                        <StackPanel>
                                            <Border
                                                x:Name="separator"
                                                Visibility="Collapsed">
                                                <Border.Margin>
                                                    <Thickness
                                                        Left="{StaticResource Spacing8}"
                                                        Top="{StaticResource Spacing8}"
                                                        Right="{StaticResource Spacing8}"
                                                        Bottom="{StaticResource Spacing8}"/>
                                                </Border.Margin>
                                                <TextBlock
                                                    Style="{StaticResource LabelMedium}"
                                                    Foreground="{StaticResource OnSurfaceVariantBrush}"
                                                    Text="{x:Static res:Strings.CompletedTasks_SectionTitle}">
                                                </TextBlock>
                                            </Border>
                                            <ItemsPresenter/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Name}" Value="True">
                                                <Setter TargetName="separator" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </controls:TaskListBox.GroupStyle>
        </controls:TaskListBox>
    </Grid>
</UserControl>


