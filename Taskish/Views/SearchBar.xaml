<UserControl x:Class="Taskish.Views.SearchBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Taskish.Controls">

    <Border
        Background="{StaticResource SurfaceContainerBrush}"
        BorderBrush="{StaticResource PrimaryBrush}"
        BorderThickness="2"
        CornerRadius="{StaticResource Corner16}">
        <Border.Padding>
            <Thickness
                Left="{StaticResource Spacing4}"
                Top="{StaticResource Spacing4}"
                Right="{StaticResource Spacing8}"
                Bottom="{StaticResource Spacing4}"/>
        </Border.Padding>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="{StaticResource Gap4}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <controls:IconButton
                Grid.Column="0"
                IconData="{StaticResource BackIcon}"
                Command="{Binding BackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>

            <TextBox
                x:Name="SearchTextBox"
                Grid.Column="2"
                Background="Transparent"
                BorderThickness="0"
                Padding="0"
                VerticalAlignment="Center"
                Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                FontSize="14"
                Foreground="{StaticResource OnSurfaceBrush}"/>
        </Grid>
    </Border>
</UserControl>
