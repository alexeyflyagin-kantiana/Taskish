<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Taskish.Controls"
                    xmlns:res="clr-namespace:Taskish.Resources">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Taskish;component/Themes/Theme.xaml"/>
        <ResourceDictionary Source="/Taskish;component/Themes/Controls/IconButtonSmallSurface.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="local:TaskTitleTextBox">
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
        <Setter Property="FontFamily" Value="pack://application:,,,/Fonts/Inter/#Inter"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:TaskTitleTextBox">
                    <Border
                        x:Name="border"
                        Background="Transparent"
                        CornerRadius="{StaticResource Corner8}"
                        BorderThickness="0"
                        BorderBrush="{StaticResource PrimaryBrush}">
                        <Border.Padding>
                            <Thickness
                                Left="{StaticResource Spacing12}"
                                Top="{StaticResource Spacing8}"
                                Right="{StaticResource Spacing8}"
                                Bottom="{StaticResource Spacing8}"/>
                        </Border.Padding>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                x:Name="placeholder"
                                Grid.Column="0"
                                Text="Без названия"
                                Style="{StaticResource TitleMedium}"
                                Foreground="{StaticResource OnSurfaceBrush}"
                                Opacity="{StaticResource Opacity-40}"
                                Visibility="Collapsed"
                                TextWrapping="Wrap"/>

                            <TextBlock
                                x:Name="textBlock"
                                Grid.Column="0"
                                Text="{TemplateBinding Text}"
                                Style="{StaticResource TitleMedium}"
                                Foreground="{TemplateBinding Foreground}"
                                TextWrapping="Wrap"/>

                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Grid.Column="0"
                                Visibility="Collapsed"/>

                            <Grid
                                x:Name="actionsGroup"
                                Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="{StaticResource Gap4}"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.Margin>
                                    <Thickness Left="{StaticResource Spacing8}"/>
                                </Grid.Margin>

                                <Viewbox
                                    x:Name="stateIcon"
                                    Grid.Row="0"
                                    Height="14" Width="14"
                                    Visibility="Hidden">
                                    <Canvas Height="14" Width="14">
                                        <Path
                                            x:Name="stateIconData"
                                            Data="{StaticResource EditSquareSmallIcon}"
                                            Fill="{StaticResource OnSurfaceBrush}"
                                            Opacity="{StaticResource Opacity-40}"/>
                                    </Canvas>
                                </Viewbox>
                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="textBlock" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="stateIcon" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="border" Property="Background" Value="{StaticResource OnSurfaceBrush4}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="PART_ContentHost" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="textBlock" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBrush8}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="{StaticResource Stroke2Thickness}"/>
                            <Setter TargetName="actionsGroup" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsBlocked" Value="True">
                            <Setter Property="Focusable" Value="False"/>
                            <Setter TargetName="stateIconData" Property="Data" Value="{StaticResource LockSmallIcon}"/>
                            <Setter TargetName="stateIcon" Property="ToolTip" Value="{x:Static res:Strings.NotAllowedToBeEdited}"/>
                            <Setter TargetName="textBlock" Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>