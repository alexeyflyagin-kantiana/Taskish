<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Taskish.Controls">


    <Style TargetType="local:Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
        <Setter Property="ShowIcon" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:Button">
                    <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{StaticResource Corner12}"
                        Height="34">
                        <Border.Padding>
                            <Thickness 
                                Left="{StaticResource Spacing8}"
                                Right="{StaticResource Spacing12}"/>
                        </Border.Padding>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox x:Name="icon" Width="14" Height="14">
                                <Viewbox.Margin>
                                    <Thickness Right="{StaticResource Spacing4}"/>
                                </Viewbox.Margin>
                                <Canvas Width="24" Height="24">
                                    <Path Data="{TemplateBinding IconData}" Fill="{TemplateBinding Foreground}"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock
                                Text="{TemplateBinding Text}" 
                                Style="{StaticResource LabelMedium}"
                                Foreground="{TemplateBinding Foreground}"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowIcon" Value="False">
                            <Setter TargetName="icon" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="border" Property="Padding">
                                <Setter.Value>
                                    <Thickness Left="12" Right="12"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource OnSurfaceBrush8}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource OnSurfaceBrush8}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>