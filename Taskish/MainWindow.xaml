<Window x:Class="Taskish.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Taskish.Views"
        xmlns:vm="clr-namespace:Taskish.ViewModels"
        xmlns:controls="clr-namespace:Taskish.Controls"
        mc:Ignorable="d"
        Title="MainWindow"
        MinHeight="540"
        MinWidth="900"
        WindowStyle="None"
        Background="{StaticResource SurfaceContainerBrush}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:TaskListViewModel}">
            <views:TaskListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StatisticsViewModel}">
            <views:StatisticsView/>
        </DataTemplate>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="48"
            ResizeBorderThickness="5"
            GlassFrameThickness="0"
            NonClientFrameEdges="None"/>
    </WindowChrome.WindowChrome>

    <Grid
        x:Name="RootGrid"
        Background="{StaticResource SurfaceContainerBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <views:TitleBar Grid.Row="0"/>

        <Grid Grid.Row="1">
            <Grid.Margin>
                <Thickness
                    Left="{StaticResource Spacing8}"
                    Right="{StaticResource Spacing8}"
                    Bottom="{StaticResource Spacing8}"/>
            </Grid.Margin>

            <!-- Фоновый контент — отключается когда открыт диалог -->
            <Grid IsEnabled="{Binding CurrentDialog, Converter={StaticResource NullToBoolConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="{StaticResource Gap4}"/>
                    <ColumnDefinition Width="440"/>
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="{StaticResource Corner8}">
                    <views:TaskListView DataContext="{Binding TaskListViewModel}"/>
                </Border>

                <Border
                    Grid.Column="2"
                    Background="{StaticResource SurfaceContainerLowestBrush}"
                    CornerRadius="{StaticResource Corner8}">
                    <ContentControl Content="{Binding CurrentRightView}"/>
                </Border>
            </Grid>

            <!-- Overlay -->
            <Grid
                Visibility="{Binding CurrentDialog, Converter={StaticResource NullToVisibilityConverter}}"
                KeyboardNavigation.TabNavigation="Cycle"
                KeyboardNavigation.DirectionalNavigation="Cycle"
                FocusManager.IsFocusScope="True">
                <Border
                    Background="{StaticResource OnSurfaceBrush}"
                    Opacity="0.4"
                    CornerRadius="{StaticResource Corner8}"/>
                <views:TaskDialogView DataContext="{Binding CurrentDialog}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
